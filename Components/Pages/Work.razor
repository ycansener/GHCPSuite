@page "/workspace/work"
@page "/work"
@inject ICopilotWorkService WorkService
@inject NavigationManager Navigation

<PageTitle>GHCP Suite | Workspace Work</PageTitle>

@if (_loading)
{
    <p class="empty-state">Loading workspace work...</p>
}
else if (_snapshot is null)
{
    <section class="panel-card">
        <div class="section-title">Workspace work</div>
        <p class="empty-state">Choose a workspace first to see its workboard.</p>
        <div class="panel-actions">
            <a class="action-button" href="/">Change workspace</a>
        </div>
    </section>
}
else
{
    <h1>@_snapshot.Workspace.Name work</h1>

    <section class="panel-card">
        <div class="section-title">Workspace workboard</div>
        <p class="panel-copy">
            This view stays inside the current workspace and only shows work linked to <code>@_snapshot.Workspace.Name</code>.
        </p>
        <div class="panel-actions">
            <a class="action-button" href="/workspace">Open overview</a>
            <a class="action-button action-button-ghost" href="/workspace/sessions">Open workspace sessions</a>
            <a class="action-button action-button-ghost" href="/workspace/tickers">Open workspace tickers</a>
            <a class="action-button action-button-ghost" href="/workspace/agents">Open workspace agents</a>
        </div>
    </section>

    <section class="panel-grid">
        <article class="panel-card">
            <div class="panel-label">Sessions</div>
            <div class="panel-metric">@_snapshot.Telemetry.SessionCount</div>
            <div class="panel-copy">Tracked sessions scoped to this workspace.</div>
        </article>
        <article class="panel-card">
            <div class="panel-label">Active</div>
            <div class="panel-metric">@_snapshot.Telemetry.ActiveSessions</div>
            <div class="panel-copy">Sessions currently in progress.</div>
        </article>
        <article class="panel-card">
            <div class="panel-label">Blocked</div>
            <div class="panel-metric">@_snapshot.Telemetry.BlockedSessions</div>
            <div class="panel-copy">Sessions waiting on an unblock.</div>
        </article>
        <article class="panel-card">
            <div class="panel-label">Done</div>
            <div class="panel-metric">@DoneSessionCount</div>
            <div class="panel-copy">Sessions already completed.</div>
        </article>
        <article class="panel-card">
            <div class="panel-label">Tickers</div>
            <div class="panel-metric">@_snapshot.Telemetry.TickerCount</div>
            <div class="panel-copy">@_snapshot.Telemetry.EnabledTickers enabled recurring task(s).</div>
        </article>
        <article class="panel-card">
            <div class="panel-label">Agents</div>
            <div class="panel-metric">@_snapshot.AgentsUsed.Count</div>
            <div class="panel-copy">Agents observed or assigned inside this workspace.</div>
        </article>
    </section>

    <section class="panel-card">
        <div class="settings-grid">
            <div class="settings-field">
                <label>Search</label>
                <input class="terminal-input" @bind="_searchFilter" @bind:event="oninput" placeholder="Name, summary, next action, or project" />
            </div>
            <div class="settings-field">
                <label>Status</label>
                <select class="terminal-input" @bind="_statusFilter">
                    <option value="">All statuses</option>
                    @foreach (var status in WorkflowStatuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
        </div>
    </section>

    <section class="content-grid">
        <article class="panel-card">
            <div class="section-title">Needs attention</div>
            @if (AttentionSessions.Count == 0)
            {
                <p class="empty-state">Nothing urgent is bubbling up in this workspace right now.</p>
            }
            else
            {
                @foreach (var session in AttentionSessions)
                {
                    <div class="list-row">
                        <div>
                            <div class="row-title"><a href="/sessions/@session.SessionId">@session.Name</a></div>
                            @if (!string.IsNullOrWhiteSpace(session.Description))
                            {
                                <div class="row-description">@session.Description</div>
                            }
                            <div class="row-meta">@session.WorkflowStatus · @(session.Project ?? "No project")</div>
                            @if (!string.IsNullOrWhiteSpace(session.NextAction))
                            {
                                <div class="row-meta">Next: @session.NextAction</div>
                            }
                        </div>
                        <div class="row-side">
                            <span class="status-pill @GetWorkflowClass(session.WorkflowStatus)">@session.WorkflowStatus</span>
                        </div>
                    </div>
                }
            }
        </article>

        <article class="panel-card">
            <div class="section-title">Recent activity</div>
            @if (_snapshot.RecentActivity.Count == 0)
            {
                <p class="empty-state">No tracked activity yet.</p>
            }
            else
            {
                <div class="timeline-list">
                    @foreach (var entry in _snapshot.RecentActivity)
                    {
                        <div class="timeline-item">
                            <div class="timeline-meta">@FormatDate(entry.Timestamp) · @FormatActivityType(entry.Type)</div>
                            <div class="row-title">@entry.Title</div>
                            <div class="row-meta">@FormatActivityContext(entry)</div>
                        </div>
                    }
                </div>
            }
        </article>
    </section>

    <section class="content-grid">
        <article class="panel-card">
            <div class="section-title">Session board</div>
            @if (FilteredSessions.Count == 0)
            {
                <p class="empty-state">No workspace sessions matched the current filters.</p>
            }
            else
            {
                <div class="table-shell">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Session</th>
                                <th>Status</th>
                                <th>Priority</th>
                                <th>Tasks</th>
                                <th>Updated</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in FilteredSessions)
                            {
                                <tr>
                                    <td>
                                        <a href="/sessions/@session.SessionId">@session.Name</a>
                                        @if (!string.IsNullOrWhiteSpace(session.Description))
                                        {
                                            <div class="row-description">@session.Description</div>
                                        }
                                        <div class="row-meta">@(session.Project ?? "No project")</div>
                                        @if (!string.IsNullOrWhiteSpace(session.NextAction))
                                        {
                                            <div class="row-meta">Next: @session.NextAction</div>
                                        }
                                    </td>
                                    <td><span class="status-pill @GetWorkflowClass(session.WorkflowStatus)">@session.WorkflowStatus</span></td>
                                    <td>@session.Priority</td>
                                    <td>@session.CompletedTaskCount/@(session.CompletedTaskCount + session.OpenTaskCount)</td>
                                    <td>@FormatDate(session.UpdatedAt)</td>
                                    <td>
                                        <div class="inline-actions">
                                            <a class="action-button action-button-small" href="/sessions/@session.SessionId">Open</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="panel-card">
            <div class="section-title">Workspace automation</div>
            @if (_snapshot.Tickers.Count == 0)
            {
                <p class="empty-state">No tickers are linked to this workspace yet.</p>
            }
            else
            {
                @foreach (var ticker in _snapshot.Tickers.OrderBy(ticker => ticker.Name, StringComparer.OrdinalIgnoreCase))
                {
                    <div class="list-row">
                        <div>
                            <div class="row-title">@ticker.Name</div>
                            <div class="row-description">@ticker.Prompt</div>
                            <div class="row-meta">Every @ticker.IntervalMinutes min · @(string.IsNullOrWhiteSpace(ticker.AgentName) ? "GHCP" : $"Agent: {ticker.AgentName}")</div>
                        </div>
                        <div class="row-side">
                            <span class="status-pill @(ticker.Enabled ? "status-live" : "status-idle")">@((ticker.LastStatus ?? (ticker.Enabled ? "Scheduled" : "Disabled")))</span>
                        </div>
                    </div>
                }
            }
        </article>

        <article class="panel-card">
            <div class="section-title">Agents used</div>
            @if (_snapshot.AgentsUsed.Count == 0)
            {
                <p class="empty-state">No agents have been used in this workspace yet.</p>
            }
            else
            {
                @foreach (var agent in _snapshot.AgentsUsed)
                {
                    <div class="list-row">
                        <div>
                            <div class="row-title">@agent.Name</div>
                            <div class="row-meta">Workspace usage</div>
                        </div>
                        <div class="row-side">
                            <span>@agent.RunCount run(s)</span>
                        </div>
                    </div>
                }
            }
        </article>
    </section>
}

@code {
    private static readonly string[] WorkflowStatuses = ["Planned", "Active", "Blocked", "Done"];

    private bool _loading = true;
    private CopilotWorkspaceSnapshot? _snapshot;
    private string _searchFilter = string.Empty;
    private string _statusFilter = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        var relativePath = GetRelativePath();
        if (string.Equals(relativePath, "work", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/workspace/work", replace: true);
            return;
        }

        var activeWorkspace = await WorkService.GetActiveWorkspaceAsync();
        if (activeWorkspace is null)
        {
            _snapshot = null;
            _loading = false;
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        _snapshot = await WorkService.GetWorkspaceSnapshotAsync(activeWorkspace.Id);
        _loading = false;
    }

    private IReadOnlyList<CopilotSessionSummary> FilteredSessions => _snapshot is null
        ? Array.Empty<CopilotSessionSummary>()
        : _snapshot.Sessions
            .Where(session => string.IsNullOrWhiteSpace(_statusFilter) || string.Equals(session.WorkflowStatus, _statusFilter, StringComparison.OrdinalIgnoreCase))
            .Where(session => MatchesSearch(session, _searchFilter))
            .OrderByDescending(session => session.UpdatedAt ?? session.CreatedAt ?? DateTimeOffset.MinValue)
            .ToArray();

    private IReadOnlyList<CopilotSessionSummary> AttentionSessions => FilteredSessions
        .Where(session =>
            string.Equals(session.WorkflowStatus, "Blocked", StringComparison.OrdinalIgnoreCase)
            || string.Equals(session.WorkflowStatus, "Active", StringComparison.OrdinalIgnoreCase)
            || !string.IsNullOrWhiteSpace(session.NextAction))
        .Take(8)
        .ToArray();

    private int DoneSessionCount => _snapshot?.Sessions.Count(session => string.Equals(session.WorkflowStatus, "Done", StringComparison.OrdinalIgnoreCase)) ?? 0;

    private static bool MatchesSearch(CopilotSessionSummary session, string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return true;
        }

        return Contains(session.Name, query)
            || Contains(session.Description, query)
            || Contains(session.Project, query)
            || Contains(session.NextAction, query)
            || Contains(session.SessionId, query);
    }

    private static bool Contains(string? value, string query) =>
        !string.IsNullOrWhiteSpace(value) && value.Contains(query, StringComparison.OrdinalIgnoreCase);

    private string GetRelativePath()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var queryIndex = relativePath.IndexOf('?');
        return (queryIndex >= 0 ? relativePath[..queryIndex] : relativePath).Trim('/');
    }

    private static string FormatActivityType(string type) => type switch
    {
        "agent-run" => "Agent run",
        "session-resume" => "Session resume",
        "workspace-session-start" => "Workspace start",
        "workspace-open" => "Workspace open",
        "ticker-run" => "Ticker run",
        "config-open" => "Config edit",
        "work-save" => "Work updated",
        "template-apply" => "Template applied",
        _ => "Activity"
    };

    private static string FormatActivityContext(CopilotActivityEntry entry)
    {
        var parts = new[]
        {
            entry.Project,
            entry.SessionName,
            entry.AgentName
        }.Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" · ", parts);
    }

    private static string GetWorkflowClass(string status) => status switch
    {
        "Active" => "status-live",
        "Blocked" => "status-warn",
        "Done" => "status-done",
        _ => "status-idle"
    };

    private static string FormatDate(DateTimeOffset? value) => value?.ToLocalTime().ToString("g") ?? "Unknown";

    private static string FormatDate(DateTimeOffset value) => value.ToLocalTime().ToString("g");
}
